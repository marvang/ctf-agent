
OPENROUTER_API_KEY=

# =============================================================================
# OPTIONAL: Discord Notifications
# =============================================================================
# To enable Discord notifications, create a Discord application and bot:
# 1. Go to https://discord.com/developers/applications
# 2. Create a new application and add a bot
# 3. Copy the bot token below
# 4. Invite the bot to your server with appropriate permissions

# Bot token for sending notifications
DISCORD_MAIN_BOT_TOKEN=

# Server (guild) ID where notifications will be sent
DISCORD_GUILD_ID=

# Category ID for organizing experiment channels (optional)
DISCORD_PARENT_CATEGORY_ID=
